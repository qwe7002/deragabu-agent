From: Deragabu Agent <deragabu@localhost>
Date: Thu, 01 Jan 2026 00:00:00 +0000
Subject: [PATCH 1/6] cmake: add Homebrew OpenSSL and Opus include paths

On macOS with Homebrew, headers are at non-standard locations
(e.g. /opt/homebrew/opt/openssl@3/include). Add OPENSSL_INCLUDE_DIR
and the opus pkg-config parent directory to the include search path.

---
 cmake/dependencies/common.cmake | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/cmake/dependencies/common.cmake b/cmake/dependencies/common.cmake
index b6afdfb2..8c850f6f 100644
--- a/cmake/dependencies/common.cmake
+++ b/cmake/dependencies/common.cmake
@@ -18,9 +18,17 @@ add_subdirectory("${CMAKE_SOURCE_DIR}/third-party/libdisplaydevice")
 # common dependencies
 include("${CMAKE_MODULE_PATH}/dependencies/nlohmann_json.cmake")
 find_package(OpenSSL REQUIRED)
+include_directories(SYSTEM ${OPENSSL_INCLUDE_DIR})
 find_package(PkgConfig REQUIRED)
 find_package(Threads REQUIRED)
 pkg_check_modules(CURL REQUIRED libcurl)
+pkg_check_modules(OPUS REQUIRED opus)
+# opus.pc Cflags points to .../include/opus but code uses #include <opus/...>
+# so add the parent directory to the include path
+foreach(_opus_inc ${OPUS_INCLUDE_DIRS})
+  get_filename_component(_opus_parent "${_opus_inc}" DIRECTORY)
+  include_directories(SYSTEM "${_opus_parent}")
+endforeach()

 # miniupnp
 pkg_check_modules(MINIUPNP miniupnpc REQUIRED)
